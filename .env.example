# App
NEXT_PUBLIC_APP_NAME="DailyHub AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_TIMEZONE="Asia/Bangkok"

# Database mode
USE_SUPABASE="false"
ALLOW_MOCK_USER="true"

# Supabase client-side publishable key
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Supabase server-side secret/service key - backend only
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# OpenAI - backend only
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
OPENAI_BASE_URL="https://api.openai.com/v1"
ENABLE_OPENAI="false"
OPENAI_FALLBACK_TO_MOCK="true"

# Translation Layer
AI_TRANSLATION_ENABLED="true"
TRANSLATION_TARGET_LANGUAGE="th"

# Telegram - backend only
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_BASE_URL="https://api.telegram.org"
ENABLE_TELEGRAM="false"
TELEGRAM_FALLBACK_TO_MOCK="true"

# Scheduler
ENABLE_SCHEDULER="true"
CRON_SECRET="change-this-cron-secret"
SCHEDULER_SECRET="change-this-cron-secret"

# Phase 16 Data Sources
ENABLE_REAL_DATA_SOURCES="false"
ENABLE_NEWS_SOURCE="false"
NEWS_API_KEY=""
NEWS_QUERY="artificial intelligence OR technology"

ENABLE_WEATHER_SOURCE="false"
WEATHER_LATITUDE="13.7563"
WEATHER_LONGITUDE="100.5018"
WEATHER_LOCATION_NAME="Bangkok"

ENABLE_GMAIL_SOURCE="false"
ENABLE_PRODUCT_SOURCE="false"
ENABLE_FOOTBALL_SOURCE="false"
ENABLE_CONCERT_SOURCE="false"
