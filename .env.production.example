# ==============================================================
# DailyHub AI — Production Environment (Vercel)
# คัดลอกไฟล์นี้ แล้วกรอกค่าจริงใน Vercel Dashboard
# Settings → Environment Variables
# ==============================================================

# App
NEXT_PUBLIC_APP_NAME="DailyHub AI"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"   # ← เปลี่ยนเป็น URL จริง
APP_TIMEZONE="Asia/Bangkok"

# Auth — ไม่ใช้ Supabase, ใช้ mock user
USE_SUPABASE="false"
ALLOW_MOCK_USER="true"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# OpenAI ← ใส่ key จริง
ENABLE_OPENAI="true"
OPENAI_API_KEY="sk-..."                              # ← key จาก platform.openai.com
OPENAI_MODEL="gpt-4o-mini"                          # ประหยัด / หรือ gpt-4o ถ้าต้องการคุณภาพสูง
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_FALLBACK_TO_MOCK="false"                     # production ไม่ควร fallback เงียบๆ

# Telegram ← ใส่ token จริง
ENABLE_TELEGRAM="true"
TELEGRAM_BOT_TOKEN="..."                            # ← จาก @BotFather
TELEGRAM_CHAT_ID="..."                              # ← chat id ที่ต้องการส่ง
TELEGRAM_BASE_URL="https://api.telegram.org"
TELEGRAM_FALLBACK_TO_MOCK="false"

# Scheduler — Vercel Cron จะ call /api/scheduler/tick ทุก 1 นาที
ENABLE_SCHEDULER="true"
USE_MOCK_DATA="true"
CRON_SECRET="generate-a-strong-random-secret-here"  # ← ต้องเปลี่ยน! ใช้ openssl rand -hex 32
SCHEDULER_SECRET="generate-a-strong-random-secret-here"  # ← ต้องเหมือนกับ CRON_SECRET

# Admin Dashboard
ADMIN_SECRET="generate-another-strong-secret-here"  # ← ใช้ openssl rand -hex 32
ENABLE_ADMIN_DASHBOARD="true"
ADMIN_EMAILS=""

# Usage Limits
ENABLE_USAGE_LIMITS="true"
DAILY_RUN_NOW_LIMIT="30"
DAILY_OPENAI_CALL_LIMIT="100"
DAILY_TELEGRAM_LIMIT="100"
MAX_TASKS_PER_USER="50"

# Data Sources — เปิดเมื่อมี API key พร้อม
ENABLE_REAL_DATA_SOURCES="true"
ENABLE_NEWS_SOURCE="true"
NEWS_API_KEY="..."                                  # ← จาก newsapi.org (free tier)
NEWS_QUERY="artificial intelligence OR technology"

ENABLE_WEATHER_SOURCE="true"
WEATHER_LATITUDE="13.7563"
WEATHER_LONGITUDE="100.5018"
WEATHER_LOCATION_NAME="Bangkok"
# Weather ใช้ open-meteo.com ฟรี ไม่ต้องมี API key
